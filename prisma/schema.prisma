generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  price       Decimal  @db.Decimal(10, 2)
  category    String
  image       String
  description String
  features    String[]
  stock       Int      @default(0)
}
